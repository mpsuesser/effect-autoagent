{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "effect-autoagent",
  "version": "0.3.0",
  "description": "Meta-agent framework that autonomously iterates on an AI agent harness by modifying prompts, tools, and orchestration, then hill-climbing on benchmark scores",
  "keywords": [
    "agent",
    "ai",
    "anthropic",
    "atif",
    "benchmark",
    "effect",
    "llm",
    "meta-agent",
    "openai"
  ],
  "homepage": "https://github.com/mpsuesser/effect-autoagent#readme",
  "bugs": {
    "url": "https://github.com/mpsuesser/effect-autoagent/issues"
  },
  "license": "MIT",
  "author": "Marc Suesser",
  "repository": {
    "type": "git",
    "url": "https://github.com/mpsuesser/effect-autoagent.git"
  },
  "bin": {
    "effect-autoagent": "./src/main.ts"
  },
  "files": [
    "src",
    "examples",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "vp build",
    "check": "vp check --fix",
    "test": "vitest run",
    "typecheck": "tsgo",
    "prepare": "effect-tsgo patch"
  },
  "dependencies": {
    "@effect/ai-anthropic": "4.0.0-beta.43",
    "@effect/ai-openai": "4.0.0-beta.43",
    "@effect/platform-bun": "4.0.0-beta.43",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@effect/tsgo": "^0.1.1",
    "@effect/vitest": "4.0.0-beta.43",
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "effect": "4.0.0-beta.43",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.15",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.43"
  },
  "overrides": {
    "effect": "4.0.0-beta.43",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.15"
  },
  "packageManager": "bun@1.3.11"
}
